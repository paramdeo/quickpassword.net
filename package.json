{
  "name": "quickpassword.net",
  "version": "1.1.1",
  "description": "A password generator that covers 99% of use cases.",
  "scripts": {
    "jekyll-serve": "bundle exec jekyll serve",
    "jekyll-clean": "rm -rf _site",
    "purge-cloudflare": "ruby purge-cloudflare.rb",
    "staging-deploy": "bundle exec jekyll build && netlifyctl deploy --draft --publish-directory _site",
    "preproduction-deploy": "bundle exec jekyll build; purgecss --css _site/style.css --content _site/index.html --output _site/style.css",
    "production-deploy": "netlifyctl deploy --publish-directory _site && node ./node_modules/npm-delay 2000 && ruby purge-cloudflare.rb"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:paramdeo/quickpassword.net.git"
  },
  "author": "Paramdeo Singh",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/paramdeo/quickpassword.net/issues"
  },
  "homepage": "https://quickpassword.net",
  "dependencies": {
    "bootstrap": "^5.0.0-beta2",
    "npm-delay": "^1.0.4"
  },
  "devDependencies": {
    "purgecss": "^4.0.3"
  }
}
